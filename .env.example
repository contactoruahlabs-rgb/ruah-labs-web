# ============================================================
# RUAH LABS — Variables de entorno
# Copia este archivo como .env.local (NO subir .env.local a git)
# ============================================================

# ---- APLICACIÓN ----
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://ruahlabs.cl
# O en desarrollo:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- SUPABASE ----
# Obtener desde: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Solo para operaciones de servidor (admin, webhooks) — NO exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- MERCADO PAGO ----
# Obtener desde: https://www.mercadopago.cl/developers/panel/app
# Usar credenciales de PRODUCCIÓN solo cuando todo esté probado
MERCADOPAGO_ACCESS_TOKEN=YOUR_MERCADOPAGO_ACCESS_TOKEN
MERCADOPAGO_PUBLIC_KEY=YOUR_MERCADOPAGO_PUBLIC_KEY

# Para pruebas (sandbox):
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID de usuario de MercadoPago (para validar webhooks)
MERCADOPAGO_USER_ID=YOUR_MERCADOPAGO_USER_ID

# Clave secreta para validar firma de webhooks de MercadoPago
MERCADOPAGO_WEBHOOK_SECRET=YOUR_MERCADOPAGO_WEBHOOK_SECRET

# ---- RESEND ----
# Obtener desde: https://resend.com/api-keys
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Dominio verificado en Resend para enviar emails
RESEND_FROM_EMAIL=noreply@ruahlabs.cl
RESEND_FROM_NAME=RUAH LABS

# ---- CONFIGURACIÓN DE NEGOCIO ----
# Email del equipo para notificaciones internas
ADMIN_NOTIFICATION_EMAIL=hola@ruahlabs.cl

# Teléfono de contacto para WhatsApp CTA
WHATSAPP_NUMBER=56900000000

# ---- SECRETOS DE APP ----
# Clave para firmar cookies de sesión (generar con: openssl rand -base64 32)
SESSION_SECRET=YOUR_SESSION_SECRET_KEY

# ---- OPCIONAL: ANALYTICS ----
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_HOTJAR_ID=XXXXXXX

# ============================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================================
#
# 1. SUPABASE:
#    a. Crear proyecto en https://app.supabase.com
#    b. Ir a Settings → API → copiar URL y keys
#    c. Ejecutar migrations/001_initial_schema.sql en SQL Editor
#    d. Ejecutar migrations/002_storage_buckets.sql
#    e. Crear usuario admin: Auth → Users → Invite user
#    f. Asignar role admin: SQL Editor → UPDATE profiles SET role='admin' WHERE id='<uuid>'
#
# 2. MERCADO PAGO:
#    a. Crear cuenta en https://www.mercadopago.cl
#    b. Ir a Developers → Panel → Crear aplicación
#    c. Obtener credentials de prueba primero
#    d. Configurar webhook URL: https://ruahlabs.cl/api/webhooks/mercadopago
#    e. Seleccionar eventos: payment (created, updated)
#
# 3. RESEND:
#    a. Crear cuenta en https://resend.com
#    b. Verificar dominio ruahlabs.cl (agregar registros DNS)
#    c. Crear API key con permisos de envío
#    d. Configurar remitente: noreply@ruahlabs.cl
#
# 4. DEPLOY EN VERCEL:
#    a. Conectar repositorio GitHub
#    b. Agregar todas las variables de entorno en Vercel Dashboard
#    c. Las variables NEXT_PUBLIC_* se exponen al cliente
#    d. Las demás son solo servidor
# ============================================================
