{
  "name": "ruah-labs-web",
  "compatibility_date": "2024-09-23",
  "main": "src/worker.js",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "ruahlabs.cl/*", "zone_name": "ruahlabs.cl" },
    { "pattern": "www.ruahlabs.cl/*", "zone_name": "ruahlabs.cl" }
  ]
}
